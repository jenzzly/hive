rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function uid()    { return request.auth.uid; }
    function authed() { return request.auth != null; }
    function role() {
      return get(/databases/$(database)/documents/users/$(uid())).data.role;
    }
    function isSuperAdmin() { return authed() && role() == 'superAdmin'; }
    function isAdmin()      { return authed() && role() == 'admin'; }
    function isOwner()      { return authed() && role() == 'owner'; }
    function isTenant()     { return authed() && role() == 'tenant'; }
    function isPriv()       { return isSuperAdmin() || isAdmin(); }

    // ── SUPER ADMIN UNIVERSAL ACCESS ──
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // ── USERS ──
    match /users/{userId} {
      allow read:   if authed();
      allow create: if authed() && uid() == userId;
      allow update: if authed() && (uid() == userId || isPriv());
      allow delete: if isSuperAdmin();
    }

    // ── PROPERTIES ──
    match /properties/{propertyId} {
      allow read: if isPriv() || (resource.data.isPublic == true && resource.data.status == 'available') || authed();
      allow create: if isPriv() || (isOwner() && request.resource.data.ownerId == uid());
      allow update, delete: if isPriv() || (isOwner() && resource.data.ownerId == uid());
    }

    // ── UNITS ──
    match /units/{unitId} {
      allow read: if true; 
      allow write: if isPriv() || (isOwner() && request.resource.data.ownerId == uid());
    }

    // ── CONTRACTS ──
    match /contracts/{contractId} {
      allow read: if isPriv() || (authed() && (resource.data.tenantId == uid() || resource.data.ownerId == uid()));
      allow create, update: if isPriv() || (isOwner() && request.resource.data.ownerId == uid()) || (authed() && resource.data.tenantId == uid());
      allow delete: if isPriv();
    }

    // ── MAINTENANCE REQUESTS ──
    match /maintenanceRequests/{reqId} {
      allow read: if authed();
      allow create: if authed() && ((isTenant() && request.resource.data.tenantId == uid()) || isPriv());
      allow update: if isPriv() || isOwner() || (isTenant() && resource.data.tenantId == uid());
      allow delete: if isPriv();
    }

    // ── BOOKING REQUESTS ──
    match /bookingRequests/{reqId} {
      allow read: if authed();
      allow create: if authed();
      allow update: if isPriv() || (isOwner() && resource.data.ownerId == uid());
      allow delete: if isPriv() || (authed() && resource.data.tenantId == uid()) || (isOwner() && resource.data.ownerId == uid());
    }

    // ── RENT PAYMENTS ──
    match /rentPayments/{payId} {
      allow read: if isPriv() || (authed() && (resource.data.tenantId == uid() || resource.data.ownerId == uid()));
      allow create: if isPriv() || (authed() && (isTenant() && request.resource.data.tenantId == uid()) || (isOwner() && request.resource.data.ownerId == uid()));
      allow update: if isPriv() || (isOwner() && resource.data.ownerId == uid());
      allow delete: if isPriv();
    }

    // ── REIMBURSEMENT REQUESTS ──
    match /reimbursementRequests/{rId} {
      allow read: if isPriv() || (authed() && (resource.data.tenantId == uid() || resource.data.ownerId == uid()));
      allow create: if isPriv() || (authed() && (isTenant() && request.resource.data.tenantId == uid()) || (isOwner() && request.resource.data.ownerId == uid()));
      allow update: if isPriv() || (isOwner() && resource.data.ownerId == uid());
      allow delete: if isPriv();
    }

    // ── PLATFORM SETTINGS ──
    match /platformSettings/{docId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    match /platform/{docId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── CONVERSATIONS ──
    match /conversations/{convId} {
      allow read: if authed();
      allow create, update: if authed();
      allow delete: if isPriv();
    }

    // ── MESSAGES ──
    match /messages/{msgId} {
      allow read: if authed();
      allow create: if authed();
      allow update, delete: if isPriv();
    }
  }
}
